@page
@model pharmacy.Pages.CartItems.EditModel
@{
    ViewData["Title"] = "Edit Cart Item";
}

<h1>Edit Cart Item</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div class="mb-3">
                <label class="form-label">Medicine</label>
                <p class="form-control-plaintext">@Model.CartItem.Medicine.Name</p>
            </div>
            <div class="mb-3">
                <label class="form-label">Unit Price</label>
                <p class="form-control-plaintext">@Model.CartItem.UnitPrice.ToString("C")</p>
            </div>
            <div class="mb-3">
                <label asp-for="CartItem.Quantity" class="form-label"></label>
                <input asp-for="CartItem.Quantity" class="form-control" min="1" />
                <span asp-validation-for="CartItem.Quantity" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
