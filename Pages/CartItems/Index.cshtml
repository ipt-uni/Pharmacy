@page
@model pharmacy.Pages.CartItems.IndexModel
@{
    ViewData["Title"] = "Cart";
}

<h1>Your Cart</h1>

@if (Model.Cart == null || !Model.Cart.CartItems.Any())
{
    <div class="alert alert-info">
        Your cart is empty. <a asp-page="/Index">Browse medicines</a> to add items.
    </div>
}
else
{
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Medicine</th>
                <th>Unit Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Cart.CartItems)
            {
                var lineTotal = item.Quantity * item.UnitPrice;
                <tr>
                    <td>
                        <a asp-page="/Medicines/Details" asp-route-id="@item.MedicineId">
                            @item.Medicine.Name
                        </a>
                    </td>
                    <td>@item.UnitPrice.ToString("C")</td>
                    <td>
                        <form method="post" asp-page-handler="Decrease"
                              asp-route-cartItemId="@item.Id" style="display:inline">
                            <button type="submit" class="btn btn-outline-secondary btn-sm">−</button>
                        </form>
                        <span class="mx-2 fw-bold">@item.Quantity</span>
                        <form method="post" asp-page-handler="Increase"
                              asp-route-cartItemId="@item.Id" style="display:inline">
                            <button type="submit" class="btn btn-outline-secondary btn-sm">+</button>
                        </form>
                    </td>
                    <td>@lineTotal.ToString("C")</td>
                    <td>
                        <form method="post" asp-page-handler="Remove"
                              asp-route-cartItemId="@item.Id" style="display:inline">
                            <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                        </form>
                        <a asp-page="./Edit" asp-route-id="@item.Id"
                           class="btn btn-outline-primary btn-sm">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="fw-bold fs-5">
                <td colspan="3" class="text-end">Grand Total:</td>
                <td colspan="2">@Model.Cart.TotalCost.ToString("C")</td>
            </tr>
        </tfoot>
    </table>
    <form method="post" asp-page-handler="Checkout">
        <button type="submit" class="btn btn-success btn-lg w-100 mt-3">Checkout</button>
    </form>
}
