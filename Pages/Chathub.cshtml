@page
@model pharmacy.Pages.ChathubModel
@{
    ViewData["Title"] = "Chat";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Staff Chat Hub</h4>
        </div>
        <div class="card-body" style="height: 500px; overflow-y: auto;" id="chatBox">
        </div>
        <div class="card-footer">
            <div class="input-group">
                <input id = "messageInput" type="text" class="form-control" placeholder="Type a message..." />
                <button id = "sendMessageBtn" class="btn btn-primary" type="button">Send</button>
            </div>
        </div>
    </div>
</div>

<script>
    const currentUser = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(User.Identity?.Name ?? ""));
</script>
<script src="~/js/signalr/dist/browser/signalr.js"></script>
<script src="~/js/chat.js"></script>

