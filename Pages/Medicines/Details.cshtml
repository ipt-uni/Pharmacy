@page
@model pharmacy.Pages.Medicines.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Medicine</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Medicine.Company)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Medicine.Company.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Medicine.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Medicine.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Medicine.RetailPrice)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Medicine.RetailPrice)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Medicine.imageSrc)
        </dt>
        <dd class="col-sm-10">
            @* @Html.DisplayFor(model => model.Medicine.imageSrc) *@
            <img src="@Model.Medicine.imageSrc" alt="Medicine Image" style="width:100px;height:100px;" />
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Medicine.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
